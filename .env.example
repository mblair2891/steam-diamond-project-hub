# Clerk — https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional Clerk paths
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Vercel Blob — https://vercel.com/docs/storage/vercel-blob
# Create a Blob store in the Vercel dashboard, then copy the token.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx

# Twilio SMS — https://console.twilio.com
# Used to notify assigned users when tasks / media / approvals need attention.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+15551234567

# OpenAI Vision — automatic wall/door/window detection on floor plan upload
# https://platform.openai.com/api-keys — server-side only (never NEXT_PUBLIC_)
OPENAI_API_KEY=sk-xxxxxxxx
# Optional model override (default gpt-4o)
# OPENAI_VISION_MODEL=gpt-4o
